# Schueler-Tutor — Beispiel-Umgebungsvariablen
# Kopieren nach .env und ausfüllen:  cp .env.example .env
# .env wird NIEMALS committet (siehe .gitignore). Keine echten Secrets hier eintragen.

# ── Datenbank (PostgreSQL läuft als Service "db" im Docker-Stack) ──────────────
POSTGRES_USER=tutor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tutor
# DATABASE_URL wird in docker-compose.yml aus den POSTGRES_*-Werten gebildet.
# Für lokalen Betrieb ohne Docker hier direkt setzen:
# DATABASE_URL=postgresql+asyncpg://tutor:changeme@localhost:5432/tutor

# ── LLM (Anthropic) — NIEMALS loggen oder committen ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── JWT — zwei VERSCHIEDENE Secrets, niemals vermischen ───────────────────────
# Erzeugen mit:  openssl rand -hex 32
STUDENT_JWT_SECRET=replace-with-openssl-rand-hex-32
PARENT_JWT_SECRET=replace-with-DIFFERENT-openssl-rand-hex-32

# ── Kostensteuerung ───────────────────────────────────────────────────────────
DAILY_TOKEN_LIMIT=50000
COST_WARN_THRESHOLD=0.80
COST_STOP_THRESHOLD=1.00

# ── E-Mail-Alerts (wöchentlicher Report, Lernausfall, Sicherheit) ─────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=tutor@example.com
SMTP_PASS=...
PARENT_EMAIL=eltern@example.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:80
MESSAGE_RETENTION_DAYS=90

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_DEST=/backups/
